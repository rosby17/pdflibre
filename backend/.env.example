# ── Copy this to .env for local dev ──────────────────────────────────────────
# Never commit .env to Git

# App
DEBUG=false
VERSION=1.0.0

# CORS — set your Vercel frontend URL here
# Multiple origins: ALLOWED_ORIGINS=["https://pdflibre.vercel.app","https://pdflibre.com"]
ALLOWED_ORIGINS=["*"]

# File limits
MAX_FILE_SIZE_MB=100
MAX_FILES_PER_REQUEST=20
FILE_TTL_SECONDS=3600

# Rate limiting (requests per minute per IP)
RATE_LIMIT_RPM=30

# Concurrency (Railway Starter = 512MB RAM → keep at 4)
MAX_CONCURRENT_JOBS=4

# Temp directory (auto-created)
TMP_DIR=/tmp/pdflibre
