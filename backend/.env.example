# ── Copy to .env for local dev ─────────────────────────────────────────────
# Never commit .env to Git

DEBUG=false

# CORS — simple string, comma-separated, or JSON array
# Examples:
#   ALLOWED_ORIGINS=*
#   ALLOWED_ORIGINS=https://pdflibre.vercel.app
#   ALLOWED_ORIGINS=https://pdflibre.vercel.app,https://pdflibre.com
ALLOWED_ORIGINS=*

MAX_FILE_SIZE_MB=100
MAX_FILES_PER_REQUEST=20
FILE_TTL_SECONDS=3600
RATE_LIMIT_RPM=30
MAX_CONCURRENT_JOBS=4
TMP_DIR=/tmp/pdflibre
